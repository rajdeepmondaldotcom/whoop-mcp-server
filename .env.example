# WHOOP app credentials — create an app at https://developer-dashboard.whoop.com
# (Alternatively, run `whoop-mcp auth --save` once and skip env vars entirely.)
WHOOP_CLIENT_ID=your-client-id
WHOOP_CLIENT_SECRET=your-client-secret

# Must exactly match a redirect URI registered on your WHOOP app.
# WHOOP_REDIRECT_URI=http://localhost:8765/callback

# Optional overrides
# WHOOP_MCP_DIR=~/.whoop-mcp          # where tokens/config are stored
# WHOOP_MCP_TZ=America/New_York       # IANA timezone (default: system zone)
# WHOOP_MCP_LOG_LEVEL=INFO
# WHOOP_MCP_CACHE_TTL=60              # seconds
# WHOOP_MCP_TIMEOUT=30                # seconds per API request
